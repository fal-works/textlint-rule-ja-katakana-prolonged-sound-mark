{
  "name": "@fal-works/textlint-rule-ja-katakana-prolonged-sound-mark",
  "version": "0.1.0",
  "description": "textlint rule for Japanese katakana prolonged sound mark based on Microsoft Japanese Localization Style Guide",
  "keywords": [
    "japanese",
    "katakana",
    "textlintrule"
  ],
  "homepage": "https://github.com/fal-works/textlint-rule-ja-katakana-prolonged-sound-mark#readme",
  "bugs": {
    "url": "https://github.com/fal-works/textlint-rule-ja-katakana-prolonged-sound-mark/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fal-works/textlint-rule-ja-katakana-prolonged-sound-mark.git"
  },
  "files": [
    "lib/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./lib/ja-katakana-prolonged-sound-mark.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc",
    "build:dict": "node dictionary/index.ts",
    "test": "pnpm run typecheck && pnpm run build:dict && mocha 'test/**/*.test.{js,ts}' --ignore 'test/prepublish/**'",
    "prepublishOnly": "pnpm test && mocha --timeout 30000 'test/prepublish/**/*.test.{js,ts}'"
  },
  "devDependencies": {
    "@fal-works/textlint-rule-ja-katakana-prolonged-sound-mark": "file:",
    "@textlint/types": "^15.5.2",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "mocha": "^11.7.5",
    "textlint": "^15.5.2",
    "textlint-tester": "^15.5.2",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "textlint": ">=15"
  },
  "engines": {
    "node": ">=22"
  }
}
